packages: .

allow-newer:
  katip:time,template-haskell,
  prometheus:base,
  unliftio-core:base,
  ekg-core:base,
  ekg-core:ghc-prim,
  -- Needed only for the non-library only executables
  superbuffer:bytestring,
  wai-extra:wai-logger,
  wai-logger:*

constraints:
  ekg-prometheus-adapter == 0.1.0.5,

  -- katip 0.8.8.3 does not build with GHC 9.6 or below.
  -- See: https://github.com/Soostone/katip/pull/160
  katip <0.8.8.3 || >0.8.8.3,
